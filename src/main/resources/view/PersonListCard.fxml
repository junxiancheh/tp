<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0">
      <padding>
        <Insets top="5" right="5" bottom="5" left="15" />
      </padding>

      <HBox spacing="0.5" alignment="CENTER_LEFT">
        <Label fx:id="id" styleClass="cell_big_label">
          <minWidth>
            <!-- Ensures that the label text is never truncated -->
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
      </HBox>

      <FlowPane fx:id="tags" />
      <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" />
      <Label fx:id="email" styleClass="cell_small_label" text="\$email" />

      <VBox spacing="5">
        <padding>
            <Insets top="10" />
        </padding>

        <Label text="LOANS"
                  style="-fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-padding: 0 0 0 0;" />
        <VBox fx:id="loansContainer" spacing="5" />

         <!-- Adds a line in between to separate loans and reservation -->
        <Separator prefWidth="150.0">
           <padding>
              <Insets top="3" bottom="3" />
           </padding>
        </Separator>

        <Label text="RESERVATIONS"
                  style="-fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-padding: 0 0 0 0;" />
        <VBox fx:id="reservationsContainer" spacing="5" />
      </VBox>
    </VBox>
  </GridPane>
</HBox>
